{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local-ppt.example/schemas/normalized-source-units.schema.json",
  "title": "Normalized Source Units",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "pack_id",
    "deck_goal",
    "audience",
    "source_units"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "deck_goal": {
      "type": "string",
      "minLength": 1
    },
    "audience": {
      "type": "string",
      "minLength": 1
    },
    "source_units": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "unit_id",
          "source_id",
          "source_title",
          "section_id",
          "section_heading",
          "unit_kind",
          "language",
          "text",
          "claims",
          "source_binding"
        ],
        "properties": {
          "unit_id": {
            "type": "string",
            "minLength": 1
          },
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "source_title": {
            "type": "string",
            "minLength": 1
          },
          "section_id": {
            "type": "string",
            "minLength": 1
          },
          "section_heading": {
            "type": "string",
            "minLength": 1
          },
          "unit_kind": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "claims": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "source_binding": {
            "type": "string",
            "pattern": "^.+:.+$"
          }
        }
      }
    }
  }
}
